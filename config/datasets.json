        "field": "fld_nm",
        "part": "part_nm"
      },
      "amounts": {
        "budget": "cpl_amt",
        "spent": "ep_amt",
        "remain": "bdg_cash_amt",
        "natl": "bdg_ntep",
        "prov": "capep",
        "local": "sggep",
        "etc": "etc_amt"
      }
    }
